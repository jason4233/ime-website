# ═══════════════════════════════════════
# Supabase / PostgreSQL
# ═══════════════════════════════════════
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ═══════════════════════════════════════
# NextAuth
# ═══════════════════════════════════════
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-at-least-32-chars"

# ═══════════════════════════════════════
# Supabase Storage (圖片上傳用)
# ═══════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# 客戶端用（非必填，伺服器端優先使用 SERVICE_ROLE）
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# 伺服器端用，繞過 RLS → 圖片上傳必填
# 到 Supabase Dashboard → Project Settings → API → service_role (secret) 取得
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-secret"

# ═══════════════════════════════════════
# Revalidate API（後台存檔 → 前台秒更新）
# ═══════════════════════════════════════
REVALIDATE_SECRET="please-generate-32-char-random-string"

# ═══════════════════════════════════════
# 前台 site URL（用於 triggerRevalidate）
# ═══════════════════════════════════════
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ═══════════════════════════════════════
# 預設管理員（seed 用）
# ═══════════════════════════════════════
ADMIN_EMAIL="admin@ime-beauty.com"
ADMIN_PASSWORD="ime2024admin"
